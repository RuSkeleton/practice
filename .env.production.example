# Безопасный шаблон для рабочего запуска.
# Скопируйте в .env и заполните секреты до запуска.

APP_ENV=production
DEV_MODE=false

DATABASE_URL=sqlite:///./data/signage.db

# Сгенерировать:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_MIXED=true

# Эти флаги обязаны оставаться false в production.
ENABLE_DEV_BOOTSTRAP=false
DEV_BOOTSTRAP_RESET_PASSWORDS=false
SHOW_DEV_LOGIN_HINTS=false
ENABLE_PUBLIC_REGISTER_IN_DEV=false

# Используется только если таблица users пуста.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_FULL_NAME=Administrator
# INITIAL_ADMIN_EMAIL=admin@example.local

HOST=0.0.0.0
PORT=8000
ENABLE_API_DOCS=false

# Если frontend и backend работают на одном адресе, оставить пустым.
CORS_ALLOWED_ORIGINS=
