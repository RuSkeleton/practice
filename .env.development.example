# Локальная разработка. Этот файл содержит намеренно слабые demo-пароли.
# Никогда не используйте его как production .env.

APP_ENV=development
DEV_MODE=true

DATABASE_URL=sqlite:///./data/signage.db

# Если строка закомментирована, секрет генерируется заново при каждом запуске.
# Поэтому JWT из предыдущего запуска перестаёт работать — для dev это удобно.
# JWT_SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_MIXED=true

ENABLE_DEV_BOOTSTRAP=true
# false: существующие пароли не сбрасываются при каждом старте.
# true: полезно только для осознанного восстановления dev-доступа.
DEV_BOOTSTRAP_RESET_PASSWORDS=false
SHOW_DEV_LOGIN_HINTS=true
ENABLE_PUBLIC_REGISTER_IN_DEV=false

DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin123
DEV_HR_USERNAME=hr
DEV_HR_PASSWORD=12345

HOST=0.0.0.0
PORT=8000
ENABLE_API_DOCS=true
CORS_ALLOWED_ORIGINS=*
