# Общий документированный шаблон.
# Для обычной разработки удобнее копировать .env.development.example,
# для развёртывания — .env.production.example.

APP_ENV=development
DEV_MODE=true

DATABASE_URL=sqlite:///./data/signage.db

# В development JWT_SECRET_KEY можно не задавать: сервер создаст временный ключ.
# В production он обязателен и должен содержать минимум 32 случайных символа.
# JWT_SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_MIXED=true

# Все dev-послабления включаются явно.
ENABLE_DEV_BOOTSTRAP=false
DEV_BOOTSTRAP_RESET_PASSWORDS=false
SHOW_DEV_LOGIN_HINTS=false
ENABLE_PUBLIC_REGISTER_IN_DEV=false

DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin123
DEV_HR_USERNAME=hr
DEV_HR_PASSWORD=12345

# Используется только при первом запуске пустой production-базы.
INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_FULL_NAME=Administrator
# INITIAL_ADMIN_EMAIL=admin@example.local

HOST=0.0.0.0
PORT=8000
ENABLE_API_DOCS=true

# Не задавайте CORS, если frontend обслуживается тем же FastAPI origin.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
